# ============================================
# Hybrid Cloud Data Pipeline - Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ----- GCP Configuration -----
GCP_PROJECT_ID="your-gcp-project-id"
GCP_REGION="us-central1"
PATH_TO_GCP_KEYFILE="./gcp-service-account-key.json"

# ----- LocalStack / AWS Configuration -----
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
LOCALSTACK_ENDPOINT=http://localhost:4566

# ----- Bridge Application Configuration -----
SQS_QUEUE_NAME=data-processing-queue
PUBSUB_TOPIC=localstack-events
POLL_INTERVAL_SECONDS=5
SQS_WAIT_TIME_SECONDS=20

# ----- Cloud SQL Configuration -----
CLOUD_SQL_INSTANCE_CONNECTION_NAME="your-gcp-project-id:us-central1:hybrid-pipeline-db"
CLOUD_SQL_DATABASE=pipelinedb
CLOUD_SQL_USER=pipeline_user
CLOUD_SQL_PASSWORD="your-secure-password"

# ----- DynamoDB Configuration (for GCP Cloud Function write-back) -----
DYNAMODB_ENDPOINT=http://localhost:4566
DYNAMODB_TABLE_NAME=processed-records
